OPENAI_API_KEY="replace-with-your-api-key"
OPENAI_MODEL="gpt-4o-mini"
# Use `openai` for live interpretation; `fallback` keeps the offline path.
AI_MODE="openai"
AI_TIMEOUT_SECONDS="30"
ABANDONMENT_TIMEOUT_MINUTES="30"
INTERNAL_AUDIT_TOKEN="replace-with-a-long-random-internal-token"

# Supabase Postgres connection string (use the session pooler for local IPv4 clients)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@HOST:5432/postgres"
CORS_ORIGINS="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"

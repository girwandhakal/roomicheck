    "living_and_cleanliness": {
      "label": "Living & Cleanliness",
      "scale": {
        "1": "Very relaxed about clutter and chore timing",
        "3": "Keeps shared areas usable with moderate flexibility",
        "5": "Highly structured about cleanliness and chore schedules"
      }
    },
    "studying_and_sleep_habits": {
      "label": "Studying & Sleep Habits",
      "scale": {

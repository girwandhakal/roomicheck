        "3": "Prefers situational coordination and moderate accommodation",
        "5": "Needs predictable quiet, darkness, and protected routines"
      }
    },
    "socializing_and_guests": {
      "label": "Socializing & Guests",
      "scale": {
        "1": "Strongly prefers a private, low-guest room",
        "3": "Accepts occasional guests with reasonable limits",
        "5": "Enjoys a highly social room and frequent guests"
      }
    },
    "sharing_space_and_boundaries": {
      "label": "Sharing Space & Boundaries",
      "scale": {
        "1": "Very open to sharing items and space informally",
        "3": "Comfortable sharing with ordinary notice and limits",
        "5": "Needs explicit permission and firm personal boundaries"
      }
    },
    "communication_and_conflict_handling": {
      "label": "Communication & Conflict",
      "scale": {
        "1": "Usually avoids or delays direct conflict conversations",
        "3": "Prefers gentle or situational communication",
        "5": "Addresses concerns promptly, calmly, and directly"
      }
    }
